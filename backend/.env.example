# CueStats backend environment — copy to .env and fill in real values
# On the DreamHost VPS, .env lives in backend/.env and is never touched by deploys.

# MongoDB — on the VPS this is localhost; never committed to git
MONGO_URL="mongodb://localhost:27017"
DB_NAME="cuestats"

# CORS — set to your production domain (no trailing slash)
CORS_ORIGINS="https://fremontopen.com"
FRONTEND_URL="https://fremontopen.com"

# Challonge API — https://challonge.com/settings/developer
CHALLONGE_API_KEY="REPLACE_ME"

# AI — https://console.anthropic.com/
ANTHROPIC_API_KEY="REPLACE_ME"

# Auth — generate with: openssl rand -hex 32
JWT_SECRET="REPLACE_ME"

# Admin credentials (seeded on first startup)
ADMIN_EMAIL="admin@fremontopen.com"
ADMIN_PASSWORD="REPLACE_ME"

# OAuth providers — optional; leave blank to disable that login method
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
