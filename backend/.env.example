# CueStats backend environment — copy to .env and fill in real values
# On the DreamHost VPS, .env lives in backend/.env and is never committed or deployed.

# ── Database ──────────────────────────────────────────────────────────────────
# DreamHost MySQL (production):
#   DATABASE_URL=mysql+aiomysql://DB_USER:DB_PASSWORD@DB_HOST/DB_NAME
#
# DreamHost panel → Goodies → MySQL Databases:
#   1. Create a database (e.g. "cuestats")
#   2. Create a MySQL hostname (e.g. "mysql.fremontopen.com")
#   3. Create a MySQL user, assign full privileges on the database
#   4. The host is the MySQL hostname from step 2 — NOT localhost
#
# Example (your values will differ):
#   DATABASE_URL=mysql+aiomysql://cuestats_user:MyPass@mysql.fremontopen.com/cuestats
DATABASE_URL="mysql+aiomysql://CHANGEME_user:CHANGEME_password@CHANGEME_mysql_host/CHANGEME_dbname"

# ── CORS / frontend ───────────────────────────────────────────────────────────
CORS_ORIGINS="https://fremontopen.com"
FRONTEND_URL="https://fremontopen.com"

# ── Challonge API ─────────────────────────────────────────────────────────────
# Get it at: https://challonge.com/settings/developer
CHALLONGE_API_KEY="CHANGEME_challonge_api_key"

# ── Anthropic AI (powers the chat) ────────────────────────────────────────────
# Get it at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY="CHANGEME_anthropic_api_key"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="CHANGEME_run_openssl_rand_hex_32"

# Admin credentials (seeded into the database on first startup)
ADMIN_EMAIL="CHANGEME_your@email.com"
ADMIN_PASSWORD="CHANGEME_strong_password"

# ── OAuth providers (all optional — leave blank to disable) ───────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
