# Copy to backend/.env for local cache refreshes.

DATABASE_URL="sqlite+aiosqlite:///./cuestats_dev.db"

# Get it at https://challonge.com/settings/developer.
CHALLONGE_API_KEY="CHANGEME_challonge_api_key"

# Optional: set for organization-hosted tournament history such as
# https://fremontopen.challonge.com
CHALLONGE_SUBDOMAIN="fremontopen"
